        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "fields": "",
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "100 * (1 - ((avg(node_memory_MemAvailable_bytes{instance=~\"$instance\"}) + avg(node_memory_Buffers_bytes{instance=~\"$instance\"}) + avg(node_memory_Cached_bytes{instance=~\"$instance\"})) / avg(node_memory_MemTotal_bytes{instance=~\"$instance\"})))",
          "refId": "A",
          "legendFormat": "Memory Usage"
        }
      ],
      "title": "Cluster Memory Usage",
      "type": "gauge"
    },
